{
  "name": "@amphore-dev/shades",
  "version": "0.3.0",
  "description": "Library for creating animated shape visualizations on canvas.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "canvas",
    "animation",
    "visualization",
    "shapes",
    "graphics",
    "javascript",
    "web",
    "art",
    "typescript",
    "library"
  ],
  "author": "Amphore Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amphore-Dev/Shades.git"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "example": "npm run build && python3 -m http.server 8000"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "@types/node": "^25.5.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
